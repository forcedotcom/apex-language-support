{
  "name": "@salesforce/apex-lsp-client",
  "version": "1.0.0",
  "description": "Apex LSP client SDK (transport-agnostic ApexClientCore + RpcConnection port)",
  "main": "out/index.js",
  "module": "out/index.js",
  "types": "out/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "import": "./out/index.js",
      "require": "./out/index.js"
    },
    "./browser": {
      "types": "./out/browser.d.ts",
      "import": "./out/browser.js",
      "require": "./out/browser.js"
    }
  },
  "sideEffects": false,
  "files": [
    "out",
    "dist"
  ],
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/forcedotcom/apex-language-support.git",
    "directory": "packages/apex-lsp-client"
  },
  "scripts": {
    "compile": "wireit",
    "bundle": "wireit",
    "dev": "tsx esbuild.config.ts --watch",
    "test": "wireit",
    "test:coverage": "wireit",
    "clean": "rimraf out dist .wireit coverage tsconfig.tsbuildinfo",
    "clean:all": "npm run clean && rimraf node_modules",
    "lint": "wireit",
    "typecheck": "wireit"
  },
  "wireit": {
    "compile": {
      "command": "tsc --build",
      "clean": "if-file-deleted",
      "dependencies": [
        "../apex-lsp-shared:compile"
      ],
      "output": [
        "out/**"
      ],
      "files": [
        "src/**/*.ts",
        "tsconfig*.json",
        "../../tsconfig.base.json"
      ]
    },
    "bundle": {
      "command": "tsx esbuild.config.ts",
      "dependencies": [
        "compile"
      ],
      "output": [
        "dist/**"
      ],
      "files": [
        "src/**/*.ts",
        "esbuild.config.ts"
      ]
    },
    "typecheck": {
      "command": "tsc -p test/tsconfig.json --noEmit",
      "dependencies": [
        "compile"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "tsconfig.json",
        "test/tsconfig.json"
      ]
    },
    "test": {
      "command": "jest --passWithNoTests --json --outputFile=.wireit/test-results.json",
      "dependencies": [
        "compile"
      ],
      "output": [
        ".wireit/test-results.json"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "**/jest.config.cjs"
      ]
    },
    "test:coverage": {
      "command": "jest --passWithNoTests --coverage --coverageDirectory=./coverage",
      "dependencies": [
        "compile"
      ],
      "output": [
        "coverage/**"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "**/jest.config.cjs"
      ]
    },
    "lint": {
      "command": "eslint --color --cache --cache-location .eslintcache --no-error-on-unmatched-pattern src test",
      "dependencies": [
        "compile"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "eslint.config.mjs"
      ],
      "output": []
    },
    "lint:fix": {
      "command": "eslint --fix --color --cache --cache-location .eslintcache --no-error-on-unmatched-pattern src test",
      "dependencies": [
        "compile"
      ],
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "eslint.config.mjs"
      ],
      "output": []
    }
  },
  "dependencies": {
    "@salesforce/apex-lsp-shared": "*",
    "effect": "^3.21.4",
    "vscode-jsonrpc": "^8.2.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@salesforce/esbuild-presets": "^0.1.0"
  }
}
