/**
 * Contains methods for the Long primitive data type.
 * Namespace: System
 * @see https://developer.salesforce.com/docs/atlas.en-us.apexref.meta/apexref/apex_methods_system_long.htm
 */
public class Long {
	/**
	 * Returns the value of this Long as a Decimal.
	 * @return Decimal representation of this Long
	 */
	public Decimal decimalValue() { }

	/**
	 * Returns the value of this Long as a Double.
	 * @return Double representation of this Long
	 */
	public Double doubleValue() { }

	/**
	 * Returns a String representation of this Long.
	 * @return String representation
	 */
	public String format() { }

	/**
	 * Returns the Integer value for this Long.
	 * @return Integer representation of this Long
	 */
	public Integer intValue() { }

	/**
	 * Returns a Long that contains the value of the specified String.
	 * @param stringToLong The String to convert
	 * @return Long value of the String
	 */
	public static Long valueOf(String stringToLong) { }

}

