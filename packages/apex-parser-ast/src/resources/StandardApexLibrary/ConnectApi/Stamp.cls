/**
 * A user stamp.
 */
global class Stamp {

  /**
   * Description of the stamp.
   */
  global String description;

  /**
   * ID of the stamp.
   */
  global String id;

  /**
   * Image URL of the stamp.
   */
  global String imageUrl;

  /**
   * Label of the stamp.
   */
  global String label;

}