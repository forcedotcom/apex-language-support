{
  "extends": "./tsconfig.base.shared.json",
  "compilerOptions": {
    "outDir": "./out/browser",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "DOM",
      "WebWorker",
      "DOM.Iterable",
      "WebWorker.ImportScripts",
      "ESNext.AsyncIterable",
      "ESNext.Disposable"
    ],
    "tsBuildInfoFile": "./out/browser/.tsbuildinfo"
  },
  "include": [
    "src/index.browser.ts",
    "src/storage/StorageImplementations.ts",
    "src/storage/StorageFactory.ts",
    "src/utils/BrowserLogNotificationHandler.ts",
    "src/utils/EnvironmentUtils.ts",
    "src/types/**/*.ts"
  ],
  "exclude": [
    "src/**/*.node.ts",
    "src/**/*.worker.ts",
    "src/worker.ts",
    "src/index.ts",
    "src/utils/WorkerLogNotificationHandler.ts",
    "node_modules",
    "out",
    "dist",
    "esbuild.config.ts"
  ],
  "references": [
    { "path": "../apex-lsp-shared" },
    { "path": "../apex-parser-ast" },
    { "path": "../lsp-compliant-services" }
  ]
}
