{
  "extends": "./tsconfig.base.shared.json",
  "compilerOptions": {
    "outDir": "./out/node",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "tsBuildInfoFile": "./out/node/.tsbuildinfo"
  },
  "include": [
    "src/**/*.node.ts",
    "src/server.node.ts",
    "src/server/nodeServer.ts",
    "src/server/LCSAdapter.ts",
    "src/server/WorkerCoordinator.ts",
    "src/server/WorkspaceBatchHandler.ts",
    "src/utils/EnvironmentUtils.ts",
    "src/profiling/ProfilingService.ts",
    "src/types/**/*.ts",
    "src/polyfills/**/*.ts"
  ],
  "exclude": [
    "src/**/*.browser.ts",
    "src/**/*.worker.ts",
    "node_modules",
    "out",
    "dist",
    "esbuild.config.ts"
  ],
  "references": [
    { "path": "../apex-lsp-shared" },
    { "path": "../apex-parser-ast" },
    { "path": "../lsp-compliant-services" }
  ]
}
