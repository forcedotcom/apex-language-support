{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out/worker",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2022",
      "WebWorker",
      "WebWorker.ImportScripts",
      "DOM",
      "DOM.Iterable"
    ],
    "target": "ES2020",
    "types": ["webworker", "node"],
    "tsBuildInfoFile": "./out/worker/.tsbuildinfo",
    "skipLibCheck": true,
    "incremental": true,
    "typeRoots": ["./src/types", "../../node_modules/@types"]
  },
  "include": ["src/worker.ts", "src/utils/**/*.worker.ts", "src/utils/WorkerLoggerFactory.ts", "src/polyfills/**/*.ts", "src/types.ts"],
  "exclude": [
    "src/**/*.browser.ts",
    "src/**/*.node.ts",
    "src/browser.ts",
    "src/node.ts",
    "src/server/**/*.ts",
    "src/communication/**/*.ts",
    "src/utils/EnvironmentDetector.ts",
    "src/utils/EnvironmentTypeGuards.ts",
    "node_modules",
    "out",
    "dist",
    "tsup.config.ts"
  ],
  "references": [
    { "path": "../apex-lsp-shared" },
    { "path": "../apex-parser-ast" },
    { "path": "../lsp-compliant-services" }
  ]
}
