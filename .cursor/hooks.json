{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": ".claude/hooks/block-git-hook-bypass.sh",
        "matcher": "git.*--no-verify"
      }
    ],
    "afterFileEdit": [{ "command": ".claude/hooks/mark-edit.sh" }],
    "stop": [{ "command": ".claude/hooks/verify-stop.sh" }]
  }
}
