{
  "name": "@salesforce/apex-language-server",
  "version": "1.0.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "typecheck": "wireit",
    "test": "wireit",
    "test:coverage": "wireit",
    "test:perf": "wireit",
    "test:perf:quick": "QUICK=true npm run test:perf",
    "test:quality": "wireit",
    "test:coverage:report": "wireit",
    "test:web": "wireit",
    "test:web:prod": "node scripts/test-web-ext.js --prod",
    "test:web:full": "wireit",
    "test:e2e": "wireit",
    "test:e2e:debug": "npm run test:debug --workspace=e2e-tests",
    "test:e2e:server": "npm run server --workspace=e2e-tests",
    "test:e2e:visual": "npm run test:visual --workspace=e2e-tests",
    "test:e2e:web": "npm run test:e2e:web --workspace=e2e-tests",
    "test:e2e:web:chromium": "npm run test:e2e:web:chromium --workspace=e2e-tests",
    "test:e2e:desktop": "npm run test:e2e:desktop --workspace=e2e-tests",
    "test:e2e:desktop:debug": "npm run test:e2e:desktop:debug --workspace=e2e-tests",
    "test:e2e:desktop:chromium": "npm run test:e2e:desktop:chromium --workspace=e2e-tests",
    "test:e2e:desktop:webkit": "npm run test:e2e:desktop:webkit --workspace=e2e-tests",
    "test:e2e:desktop:all-browsers": "npm run test:e2e:desktop:all-browsers --workspace=e2e-tests",
    "lint": "wireit",
    "lint:fix": "wireit",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "check:dupes": "jscpd",
    "check:dupes:strict": "jscpd --threshold 0",
    "check:dupes:parser-ast": "jscpd packages/apex-parser-ast/src --config .jscpd.json --output ./jscpd-report-parser-ast --threshold 10",
    "check:dupes:parser-ast:strict": "jscpd packages/apex-parser-ast/src --config .jscpd.json --output ./jscpd-report-parser-ast --threshold 0",
    "compile": "wireit",
    "prepare": "husky",
    "clean": "wireit",
    "clean:all": "wireit",
    "sync:testbed-fixtures": "wireit",
    "semantic-release": "semantic-release",
    "bundle": "wireit",
    "package": "wireit",
    "package:packages": "npm run package",
    "package:packages:prerelease": "wireit",
    "rebuild": "npm run clean && npm run compile && npm run bundle",
    "sync:vscode-version": "wireit"
  },
  "keywords": [
    "salesforce",
    "apex",
    "language server",
    "lsp"
  ],
  "author": "Salesforce",
  "license": "BSD-3-Clause",
  "description": "Language Server Protocol implementation for Salesforce Apex",
  "repository": {
    "type": "git",
    "url": "https://github.com/forcedotcom/apex-language-support.git"
  },
  "bugs": {
    "url": "https://github.com/forcedotcom/apex-language-support/issues"
  },
  "homepage": "https://github.com/forcedotcom/apex-language-support#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.4.4",
    "@salesforce/apex-lsp-compliant-services": "1.0.0",
    "@salesforce/apex-lsp-parser-ast": "1.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tony.ganchev/eslint-plugin-header": "^3.1.2",
    "@types/benchmark": "^2.1.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "@types/semver": "^7.7.0",
    "@types/vscode": "1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vscode/test-web": "^0.0.80",
    "benchmark": "^2.1.4",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "effect": "^3.21.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^62.8.1",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-unused-imports": "^4.1.4",
    "glob": "^10.3.10",
    "husky": "^9.0.11",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.1.7",
    "jest": "^30.3.0",
    "jscpd": "^4.0.9",
    "jsonc-eslint-parser": "^2.4.0",
    "knip": "^6.4.1",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.5",
    "semantic-release": "^25.0.3",
    "semver": "^7.7.4",
    "shelljs": "^0.10.0",
    "simple-git": "^3.32.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "wireit": "^0.14.12",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "@rollup/rollup-linux-x64-musl": "^4.60.1"
  },
  "dependencies": {
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "workspaces": [
    "packages/*",
    "e2e-tests"
  ],
  "wireit": {
    "typecheck": {
      "dependencies": [
        "compile",
        "./packages/apex-parser-ast:typecheck",
        "./packages/apex-lsp-shared:typecheck",
        "./packages/apex-ls:typecheck",
        "./packages/lsp-compliant-services:typecheck",
        "./packages/apex-lsp-vscode-extension:typecheck",
        "./packages/apex-lsp-testbed:typecheck"
      ]
    },
    "sync:vscode-version": {
      "command": "node scripts/sync-vscode-version.js",
      "files": [
        "scripts/sync-vscode-version.js",
        ".vscode-version"
      ],
      "output": [],
      "cache": false
    },
    "compile": {
      "dependencies": [
        "sync:vscode-version",
        "./packages/apex-ls:compile",
        "./packages/apex-lsp-shared:compile",
        "./packages/apex-parser-ast:compile:tsc",
        "./packages/apex-parser-ast:generate:stdlib-cache",
        "./packages/lsp-compliant-services:compile",
        "./packages/custom-services:compile",
        "./packages/apex-lsp-testbed:compile",
        "./packages/apex-lsp-vscode-extension:compile",
        "./packages/esbuild-presets:compile"
      ]
    },
    "bundle": {
      "dependencies": [
        "compile",
        "./packages/apex-ls:bundle",
        "./packages/apex-lsp-shared:bundle",
        "./packages/apex-parser-ast:bundle",
        "./packages/lsp-compliant-services:bundle",
        "./packages/custom-services:bundle",
        "./packages/apex-lsp-vscode-extension:bundle"
      ]
    },
    "package": {
      "dependencies": [
        "bundle",
        "./packages/apex-lsp-vscode-extension:package",
        "./packages/apex-lsp-vscode-extension:package-web"
      ]
    },
    "package:packages:prerelease": {
      "dependencies": [
        "bundle",
        "./packages/apex-lsp-vscode-extension:package-prerelease",
        "./packages/apex-lsp-vscode-extension:package-web-prerelease"
      ]
    },
    "test": {
      "command": "node scripts/test-summary.js",
      "dependencies": [
        "compile",
        "sync:testbed-fixtures",
        "./packages/apex-ls:test",
        "./packages/apex-ls:test:web",
        "./packages/apex-lsp-shared:test",
        "./packages/apex-lsp-testbed:test",
        "./packages/apex-lsp-vscode-extension:test",
        "./packages/apex-parser-ast:test",
        "./packages/custom-services:test",
        "./packages/lsp-compliant-services:test"
      ]
    },
    "test:coverage": {
      "dependencies": [
        "compile",
        "./packages/apex-ls:test:coverage",
        "./packages/apex-lsp-shared:test:coverage",
        "./packages/apex-lsp-testbed:test:coverage",
        "./packages/apex-lsp-vscode-extension:test:coverage",
        "./packages/apex-parser-ast:test:coverage",
        "./packages/custom-services:test:coverage",
        "./packages/lsp-compliant-services:test:coverage"
      ]
    },
    "test:perf": {
      "dependencies": [
        "compile",
        "./packages/apex-lsp-testbed:test:perf",
        "./packages/apex-parser-ast:test:perf",
        "./packages/lsp-compliant-services:test:perf"
      ]
    },
    "test:quality": {
      "dependencies": [
        "compile",
        "bundle",
        "./packages/apex-lsp-testbed:test:quality"
      ]
    },
    "server": {
      "command": "npm run server --workspaces --if-present",
      "dependencies": [
        "compile"
      ],
      "cache": false
    },
    "test:debug": {
      "command": "npm run test:debug --workspaces --if-present",
      "dependencies": [
        "compile"
      ],
      "cache": false
    },
    "test:visual": {
      "command": "npm run test:visual --workspaces --if-present",
      "dependencies": [
        "compile"
      ],
      "cache": false
    },
    "test:web": {
      "command": "node scripts/test-web-ext.js",
      "dependencies": [
        "bundle"
      ],
      "cache": false
    },
    "test:web:full": {
      "command": "node scripts/test-web-ext.js --with-services",
      "dependencies": [
        "bundle"
      ],
      "cache": false
    },
    "test:e2e": {
      "command": "node scripts/test-e2e.js",
      "dependencies": [
        "bundle"
      ],
      "cache": false
    },
    "lint": {
      "command": "prettier --check \"packages/**/*.ts\"",
      "dependencies": [
        "./packages/apex-ls:lint",
        "./packages/apex-lsp-shared:lint",
        "./packages/apex-parser-ast:lint",
        "./packages/lsp-compliant-services:lint",
        "./packages/custom-services:lint",
        "./packages/apex-lsp-testbed:lint",
        "./packages/apex-lsp-vscode-extension:lint",
        "./e2e-tests:lint"
      ]
    },
    "lint:fix": {
      "command": "prettier --write \"packages/**/*.ts\" --log-level warn",
      "dependencies": [
        "compile",
        "typecheck",
        "./packages/apex-ls:lint:fix",
        "./packages/apex-lsp-shared:lint:fix",
        "./packages/apex-parser-ast:lint:fix",
        "./packages/lsp-compliant-services:lint:fix",
        "./packages/custom-services:lint:fix",
        "./packages/apex-lsp-testbed:lint:fix",
        "./packages/apex-lsp-vscode-extension:lint:fix",
        "./e2e-tests:lint:fix"
      ]
    },
    "clean": {
      "command": "npm run clean --workspaces --if-present && rimraf .wireit coverage test-artifacts",
      "cache": false
    },
    "clean:all": {
      "command": "npm run clean:all --workspaces --if-present && rimraf node_modules coverage test-artifacts",
      "cache": false
    },
    "test:coverage:report": {
      "command": "node scripts/merge-coverage.js",
      "dependencies": [
        "test:coverage"
      ],
      "output": [
        "coverage/**"
      ],
      "files": [
        "scripts/merge-coverage.js",
        "packages/*/coverage/coverage-final.json"
      ]
    },
    "sync:testbed-fixtures": {
      "command": "node scripts/sync-testbed-fixtures.js",
      "output": [
        "packages/apex-lsp-testbed/test/fixtures/i-have-problems/force-app/main/default/classes/**"
      ],
      "files": [
        "scripts/sync-testbed-fixtures.js",
        "packages/apex-parser-ast/test/fixtures/validation/**"
      ]
    }
  }
}
